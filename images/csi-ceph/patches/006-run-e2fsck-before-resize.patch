+// runE2fsckRepair runs e2fsck -fy on an unmounted ext2/3/4 device.
+// Exit codes 0–2 are treated as success.
+func runE2fsckRepair(ctx context.Context, exec utilexec.Interface, devicePath string) error {
+	format, err := getDiskFormat(exec, devicePath)
+	if err != nil {
+		return err
+	}
+	if format != "ext2" && format != "ext3" && format != "ext4" {
+		return nil
+	}
+
+	out, err := exec.Command("e2fsck", "-fy", devicePath).CombinedOutput()
+	if err == nil {
+		return nil
+	}
+	if errors.Is(err, utilexec.ErrExecutableNotFound) {
+		log.WarningLog(ctx, "e2fsck not found, skipping filesystem repair on %s", devicePath)
+
+		return nil
+	}
+
+	exitErr, ok := err.(utilexec.ExitError)
+	if ok && exitErr.ExitStatus() <= 2 {
+		log.DebugLog(ctx, "e2fsck repaired filesystem on %s: %s", devicePath, string(out))
+
+		return nil
+	}
+
+	return fmt.Errorf("e2fsck on %s failed: %w, output: %s", devicePath, err, string(out))
+}
+
+func getDiskFormat(exec utilexec.Interface, devicePath string) (string, error) {
+	args := []string{"-p", "-s", "TYPE", "-o", "export", devicePath}
+	out, err := exec.Command("blkid", args...).CombinedOutput()
+	if err != nil {
+		if errors.Is(err, utilexec.ErrExecutableNotFound) {
+			return "", nil
+		}
+
+		return "", fmt.Errorf("blkid %s failed: %w, output: %s", devicePath, err, string(out))
+	}
+
+	for _, part := range strings.Split(string(out), " ") {
+		if strings.HasPrefix(part, "TYPE=") {
+			return strings.Trim(strings.TrimPrefix(part, "TYPE="), `"`), nil
+		}
+	}
+
+	return "", nil
+}
+
+func repairExt4ForResize(
+	ctx context.Context,
+	ns *NodeServer,
+	req *csi.NodeStageVolumeRequest,
+	staticVol, fileEncryption bool,
+	transaction *stageTransaction,
+	stagingTargetPath string,
+) error {
+	devicePath := transaction.devicePath
+	if err := ns.Mounter.Unmount(stagingTargetPath); err != nil {
+		return fmt.Errorf("unmount %s before e2fsck: %w", stagingTargetPath, err)
+	}
+	if err := runE2fsckRepair(ctx, utilexec.New(), devicePath); err != nil {
+		return err
+	}
+
+	return ns.mountVolumeToStagePath(ctx, req, staticVol, stagingTargetPath, devicePath, fileEncryption)
+}
