+// runE2fsckRepair repairs an unmounted ext2/3/4 device only when a read-only
+// e2fsck check reports filesystem problems. Exit codes 0–2 after repair are
+// treated as success per e2fsck(8). The filesystem type is detected via the
+// canonical k8s.io/mount-utils helper so that LUKS/crypto/xfs devices are
+// skipped without false positives.
+func runE2fsckRepair(ctx context.Context, mounter mount.Interface, exec utilexec.Interface, devicePath string) error {
+	diskMounter := &mount.SafeFormatAndMount{Interface: mounter, Exec: exec}
+	format, err := diskMounter.GetDiskFormat(devicePath)
+	if err != nil {
+		return fmt.Errorf("detect filesystem on %s: %w", devicePath, err)
+	}
+	if format != "ext2" && format != "ext3" && format != "ext4" {
+		return nil
+	}
+
+	checkOut, checkErr := exec.Command("e2fsck", "-fn", devicePath).CombinedOutput()
+	if checkErr == nil {
+		return nil
+	}
+	if errors.Is(checkErr, utilexec.ErrExecutableNotFound) {
+		log.WarningLog(ctx, "e2fsck not found, skipping filesystem repair on %s", devicePath)
+
+		return nil
+	}
+	var checkExit utilexec.ExitError
+	if errors.As(checkErr, &checkExit) {
+		// e2fsck(8) exit codes >= 16 (usage / cancelled / library error) — repair will not help.
+		if status := checkExit.ExitStatus(); status >= 16 {
+			return fmt.Errorf("e2fsck check on %s aborted (exit %d): %s", devicePath, status, string(checkOut))
+		}
+	}
+	log.DebugLog(ctx, "e2fsck check found filesystem issues on %s: %s", devicePath, string(checkOut))
+
+	out, err := exec.Command("e2fsck", "-fy", devicePath).CombinedOutput()
+	if err == nil {
+		return nil
+	}
+	if errors.Is(err, utilexec.ErrExecutableNotFound) {
+		log.WarningLog(ctx, "e2fsck not found, skipping filesystem repair on %s", devicePath)
+
+		return nil
+	}
+	var exitErr utilexec.ExitError
+	if errors.As(err, &exitErr) && exitErr.ExitStatus() <= 2 {
+		log.DebugLog(ctx, "e2fsck repaired filesystem on %s: %s", devicePath, string(out))
+
+		return nil
+	}
+
+	return fmt.Errorf("e2fsck on %s failed: %w, output: %s", devicePath, err, string(out))
+}
+
+func repairExt4ForResize(
+	ctx context.Context,
+	ns *NodeServer,
+	req *csi.NodeStageVolumeRequest,
+	staticVol, fileEncryption bool,
+	transaction *stageTransaction,
+	devicePath, stagingTargetPath string,
+) error {
+	if err := ns.Mounter.Unmount(stagingTargetPath); err != nil {
+		return fmt.Errorf("unmount %s before e2fsck: %w", stagingTargetPath, err)
+	}
+	transaction.isMounted = false
+	if err := runE2fsckRepair(ctx, ns.Mounter, utilexec.New(), devicePath); err != nil {
+		return err
+	}
+	if err := ns.mountVolumeToStagePath(ctx, req, staticVol, stagingTargetPath, devicePath, fileEncryption); err != nil {
+		return err
+	}
+	transaction.isMounted = true
+
+	return nil
+}
